# ================================================
# CONFIGURAÇÕES TOPFOOD EMBALAGENS — copie para .env e preencha
# ================================================

# ── Servidor ──
PORT=3000
BASE_URL=http://localhost:3000          # troque pelo domínio em produção
NODE_ENV=development                      # use "production" no servidor
ALLOWED_ORIGINS=                          # CORS: lista separada por vírgula (vazio = liberado em dev)

# ── Admin / Autenticação ──
ADMIN_PASSWORD=topfood2026                # senha inicial do owner (Wellington)
ADMIN_TOKEN=                              # token de serviço opcional p/ rotas admin
JWT_SECRET=troque_por_um_segredo_forte    # OBRIGATÓRIO em produção
JWT_EXPIRES=7d

# ── E-mail de confirmação (nodemailer) ──
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_USER=
EMAIL_PASS=
EMAIL_FROM=TopFood Embalagens <contato@topfoodembalagens.com.br>

# ── Pagamentos ──
# Mercado Pago: https://www.mercadopago.com.br/settings/account/credentials
MP_ACCESS_TOKEN=SEU_ACCESS_TOKEN_AQUI
# PIX automático via Asaas (preferencial)
ASAAS_API_KEY=
# PIX dinâmico via OpenPix (alternativo)
OPENPIX_APP_ID=

# ── IA (atendente WhatsApp + insights) ──
ANTHROPIC_API_KEY=

# ── Mercado Livre (radar de concorrência) ──
ML_APP_ID=
ML_CLIENT_SECRET=

# ── NF-e ──
# Os tokens da Focus NFe NÃO ficam aqui — são configurados no painel
# (Admin → config fiscal) e salvos em settings.
